<?xml version = "1.0"  encoding = "UTF-8" ?>
  <io>
    <tool-version>2.7.0.0</tool-version>
        <code>${gmIoId}</code>
        <name>${gmName}</name>
        <io-type>${io_type}</io-type>
    <dm-code>$!{gmDmCode}</dm-code>
#if($gmIoCondition)
    <condition>${gmIoCondition}</condition>
#end
    <is-disable>false</is-disable>
    <creator>eclipse</creator>
    <create-time>2026-03-01 10:49:10.0</create-time>
    <io-parts-list/>
    <io-item-list>
#foreach($item in $!{ioItemList})
      <io-item>
        <io-code>$!{gmIoId}</io-code>
        <code>$!{item.code}</code>
#if($item.label)
        <name>$!{item.label}</name>
#else
        <name>$!{item.name}</name>
#end
        <is-visible>$!{item.is_visible}</is-visible>
        <item-type>$!{item.item_type}</item-type>
        <is-require>$!{item.is_require}</is-require>
        <length>$!{item.length}</length>
        <scale>-1</scale>
        <min-length>0</min-length>
        <max-length>0</max-length>
        <max-ByteSize>0</max-ByteSize>
#if($item.default_value)
        <default-value>$!{item.default_value}</default-value>
#end
#if($item.statement)
        <statement>$!{item.statement}</statement>
#end
#if($item.msg_code_ng)
        <msg-code-ng>${item.msg_code_ng}</msg-code-ng>
#end
#if($item.msg_param_ng)
        <msg-param-ng>${item.msg_param_ng}</msg-param-ng>
#end
#if($item.condition)
        <condition>$!{item.condition}</condition>
#end
        <level>$!{item.level}</level>
        <sort-key>0</sort-key>
#if($item.dm_code)
        <dm-code>$!{item.dm_code}</dm-code>
#end
#if($item.dm_item_code)
        <dm-item-code>$!{item.dm_item_code}</dm-item-code>
#end
#if($item.choiceInfo)
        <choice-list>
#if($item.choiceInfo.fixed)
          <fixed>$!{item.choiceInfo.fixed}</fixed>
#end
#if($item.choiceInfo.dmCode)
          <dm-code>$!{item.choiceInfo.dmCode}</dm-code>
#end
#if($item.choiceInfo.condition)
          <condition>$!{item.choiceInfo.condition}</condition>
#end
#if($item.choiceInfo.valueDmItemCode)
          <value-dm-item-code>$!{item.choiceInfo.valueDmItemCode}</value-dm-item-code>
#end
#if($item.choiceInfo.nameDmItemCode1)
          <name-dm-item-code1>$!{item.choiceInfo.nameDmItemCode1}</name-dm-item-code1>
#end
#if($item.choiceInfo.nameDmItemCode2)
          <name-dm-item-code2>$!{item.choiceInfo.nameDmItemCode2}</name-dm-item-code2>
#end
#if($item.choiceInfo.sortDmItemCode1)
          <sort-dm-item-code1>$!{item.choiceInfo.sortDmItemCode1}</sort-dm-item-code1>
#end
#if($item.choiceInfo.sortDmItemCode2)
          <sort-dm-item-code2>$!{item.choiceInfo.sortDmItemCode2}</sort-dm-item-code2>
#end
#if($item.choiceInfo.sortType1)
          <sort-type1>$!{item.choiceInfo.sortType1}</sort-type1>
#end
#if($item.choiceInfo.sortType2)
          <sort-type2>$!{item.choiceInfo.sortType2}</sort-type2>
#end
        </choice-list>
#end
#if($item.is_disable)
        <is-disable>${item.is_disable}</is-disable>
#end        
#if($item.description)
        <description>$!{item.description}</description>
#end
        <creator>eclipse</creator>
        <create-time>2026-03-01 10:49:10.0</create-time>
#if($item.io_item_prop_list)
        <io-item-prop-list>
#foreach($itemProp in $!{item.io_item_prop_list})
          <io-item-prop>
            <key>$!{itemProp.key}</key>
            <value>$!{itemProp.value}</value>
          </io-item-prop>
#end
        </io-item-prop-list>
#else
        <io-item-prop-list/>
#end
        <io-item-ext-prop-list/>
        <io-item-next-io-logic-list/>
      </io-item>
#end
