    <io-prop-list/>
    <sec-io>
        <io-code>${gmIoId}</io-code>
      <is-disable>false</is-disable>
    </sec-io>
    <sec-menu>
        <io-code>${gmIoId}</io-code>
      <is-disable>false</is-disable>
    </sec-menu>
  </io>
